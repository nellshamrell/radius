// Generated by: rad bicep generate --from-aspire
// Source: {{ .SourceDir }}
// Date: {{ .Timestamp }}

extension radius

@description('The ID of your Radius Environment. Set automatically by the rad CLI.')
param environment string

@description('The name of the Radius Application.')
param applicationName string = '{{ .App.Name }}'
{{ range .App.Parameters }}
{{ if .Description }}@description('{{ .Description }}')
{{ end }}{{ if .IsSecure }}@secure()
{{ end }}param {{ .Name }} {{ .Type }}{{ if .DefaultValue }} = '{{ .DefaultValue }}'{{ end }}
{{ end }}
resource app 'Radius.Core/applications@2025-08-01-preview' = {
  name: applicationName
  properties: {
    environment: environment
  }
}
{{ range .App.Containers }}
resource {{ .Name }} 'Radius.Compute/containers@2025-08-01-preview' = {
  name: '{{ .Name }}'
  properties: {
    application: app.id
    environment: environment
    container: {
      image: {{ .ImageParam }}
      ports: {
{{- range .Ports }}
        {{ .Name }}: {
          containerPort: {{ .ContainerPort }}
          protocol: '{{ .Protocol }}'
{{- if .IsPlaceholder }}
          /* PLACEHOLDER: port not found in Aspire artifacts — set manually */
{{- end }}
        }
{{- end }}
      }
{{- if .EnvVars }}
      env: {
{{- range $key, $value := sortedEnvVars .EnvVars }}
        {{ $key }}: '{{ $value }}'
{{- end }}
      }
{{- end }}
    }
{{- if .Connections }}
    connections: {
{{- range .Connections }}
      {{ .Name }}: {
        source: {{ .Source }}
      }
{{- end }}
    }
{{- end }}
  }
}
{{ end }}
{{- range .App.Dependencies }}
{{- if .IsPlaceholder }}
// {{ .PlaceholderComment }}
// resource {{ .Name }} — no Portable Resource equivalent available
{{- else }}
resource {{ .Name }} '{{ .Type }}@2023-10-01-preview' = {
  name: '{{ .Name }}'
  properties: {
    application: app.id
    environment: environment
  }
}
{{- end }}
{{ end }}
